# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# SUPABASE_URL: The URL of your Supabase project.
SUPABASE_URL="YOUR_SUPABASE_URL"

# SUPABASE_SERVICE_ROLE_KEY: The service role key for backend access.
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# SENDGRID_API_KEY: SendGrid API key for email notifications
SENDGRID_API_KEY="YOUR_SENDGRID_API_KEY"

# SENDGRID_FROM_EMAIL: Verified sender address in SendGrid
SENDGRID_FROM_EMAIL="YOUR_SENDGRID_FROM_EMAIL"

# GOOGLE_SERVICE_ACCOUNT_JSON (recommended): Service account key JSON as a single line
# Use this to enable server-side Google Drive auth without OAuth popup/client redirect.
# You can also provide this as base64-encoded JSON.
GOOGLE_SERVICE_ACCOUNT_JSON="YOUR_SERVICE_ACCOUNT_JSON_OR_BASE64"

# GOOGLE_SERVICE_ACCOUNT_FILE (optional): Absolute path to service-account JSON file
# Example (Windows): C:\\path\\to\\service-account.json
GOOGLE_SERVICE_ACCOUNT_FILE="YOUR_OPTIONAL_SERVICE_ACCOUNT_FILE_PATH"

# Optional alternative to GOOGLE_SERVICE_ACCOUNT_JSON:
GOOGLE_SERVICE_ACCOUNT_EMAIL="YOUR_SERVICE_ACCOUNT_EMAIL"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="YOUR_SERVICE_ACCOUNT_PRIVATE_KEY"

# Optional for Google Meet auto-link generation with a Workspace service account:
# user email to impersonate via domain-wide delegation.
GOOGLE_MEET_DELEGATED_USER="YOUR_WORKSPACE_USER_EMAIL"

# Optional: Target folder where uploaded files will be stored.
GOOGLE_DRIVE_FOLDER_ID="YOUR_OPTIONAL_DRIVE_FOLDER_ID"

# GOOGLE_CLIENT_ID (OAuth fallback): Your Google Cloud OAuth Client ID
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"

# GOOGLE_CLIENT_SECRET (OAuth fallback): Your Google Cloud OAuth Client Secret
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# GOOGLE_REDIRECT_URI (optional): Exact OAuth callback URL used for Google Drive auth.
# Example: https://your-app.up.railway.app/api/auth/google/callback
# OAuth now grants both Google Drive upload access and Google Meet link creation.
GOOGLE_REDIRECT_URI="YOUR_OPTIONAL_GOOGLE_REDIRECT_URI"

# APP_BASE_URL (optional fallback): Public base URL used to build callback URL
222-04952M
# when GOOGLE_REDIRECT_URI is not set.
# Example: https://your-app.up.railway.app
APP_BASE_URL="YOUR_OPTIONAL_PUBLIC_BASE_URL"

# APP_DATA_DIR (optional): Directory for persisted runtime files
# (uploads and drive-tokens.json). Example on Render: /var/data
APP_DATA_DIR="YOUR_OPTIONAL_APP_DATA_DIR"
